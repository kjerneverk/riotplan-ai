{
  "name": "@kjerneverk/riotplan-ai",
  "version": "1.0.1",
  "description": "AI plan generation engine for RiotPlan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run lint && vite build",
    "test": "npm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --run --coverage --reporter verbose",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "precommit": "npm run build && npm run lint && npm run test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "riotplan",
    "ai",
    "llm",
    "plan-generation",
    "provenance"
  ],
  "author": "Tim O'Brien <tobrien@discursive.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kjerneverk/riotplan-ai"
  },
  "dependencies": {
    "@kjerneverk/riotplan-format": "^1.0.2"
  },
  "peerDependencies": {
    "@kjerneverk/agentic": "^1.0.9",
    "@kjerneverk/execution": "^1.0.8",
    "@kjerneverk/execution-anthropic": "^1.0.13",
    "@kjerneverk/execution-openai": "^1.0.13",
    "@kjerneverk/execution-sampling": "^1.0.5",
    "@kjerneverk/riotplan-catalyst": "^1.0.7"
  },
  "peerDependenciesMeta": {
    "@kjerneverk/agentic": {
      "optional": true
    },
    "@kjerneverk/execution": {
      "optional": true
    },
    "@kjerneverk/execution-anthropic": {
      "optional": true
    },
    "@kjerneverk/execution-openai": {
      "optional": true
    },
    "@kjerneverk/execution-sampling": {
      "optional": true
    },
    "@kjerneverk/riotplan-catalyst": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.10.9",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  },
  "publishConfig": {
    "tag": "dev"
  }
}
